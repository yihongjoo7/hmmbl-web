# ────────────────────────────────────────────────────────────────
# 환경변수 템플릿 — 실제 값은 .env.local 에 설정 (.gitignore 대상)
# ────────────────────────────────────────────────────────────────

# 환경 구분: dev | staging | prod  (기본: dev)
NEXT_PUBLIC_APP_ENV=dev

# ── API ─────────────────────────────────────────────────────────
# dev 미설정 시 브라우저에서 /api/proxy 프록시 자동 사용 (localhost·IP 모두 동작)
# staging/prod 는 반드시 설정
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# ── 앱 공개 URL (staging/prod 필수) ─────────────────────────────
# /api/translate Origin 허용에 사용. 미설정 시 staging/prod 에서 번역 API 전체 403
# NEXT_PUBLIC_APP_URL=https://www.example.com

# ── IP 접속 허용 (dev 전용) ──────────────────────────────────────
# 개발 PC 를 IP 로 접근할 때 /_next/* 정적 파일 허용 (콤마 구분 복수 가능)
# ALLOWED_DEV_ORIGINS=192.168.1.100

# ── Google Translate (미사용 — hpoint-mobile은 Azure 사용) ────────
GOOGLE_TRANSLATE_API_KEY=

# ── Azure Translator (서버사이드 전용 — NEXT_PUBLIC_ 금지) ────────
# 동적 번역(ja/th/vi/ms) 메시지팩 생성에 사용. 실제 값은 .env.local 에 설정.
# 미설정 시 동적 locale은 원문(en) 그대로 반환된다(graceful degradation).
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=koreacentral
