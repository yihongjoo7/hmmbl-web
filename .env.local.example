# -----------------------------------------------
# 로컬 개발 환경 설정 예시 (.env.local 로 복사 후 사용)
# -----------------------------------------------

# 앱 환경 (dev | staging | prod)
NEXT_PUBLIC_APP_ENV=dev

# API 기본 URL
# - IP로 접속하는 경우
# NEXT_PUBLIC_API_BASE_URL=https://192.168.x.x:8000
# - localhost로 접속하는 경우
NEXT_PUBLIC_API_BASE_URL=https://localhost:8000

# 앱 공개 URL (dev 에서는 localhost 고정이므로 보통 불필요)
# staging/prod 배포 시 반드시 .env.local 에 실제 URL 설정
# NEXT_PUBLIC_APP_URL=https://192.168.x.x:3000

# 허용할 dev 접속 origin (IP 접속 시 /_next/* 정적 파일 허용)
# ALLOWED_DEV_ORIGINS=https://192.168.x.x:3000
