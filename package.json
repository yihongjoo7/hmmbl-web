{
  "name": "hpoint-mobile",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev --experimental-https --experimental-https-key ./keyfile/local-key.pem --experimental-https-cert ./keyfile/local-cert.pem --port 3001 --hostname 0.0.0.0",
    "dev:http": "next dev --port 3000 --hostname 0.0.0.0",
    "build": "next build",
    "build:staging": "NODE_ENV=production NEXT_PUBLIC_APP_ENV=staging next build",
    "build:prod": "NODE_ENV=production NEXT_PUBLIC_APP_ENV=prod next build",
    "start": "next start --port 3001",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.16",
    "next": "^14.2.29",
    "next-intl": "^3.26.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "^5.62.16",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.29",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
